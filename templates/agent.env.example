# Local-agent configuration only. Do not copy this file into arc-dex or arc-dex-api.
# Required: wallet used by the local ARCOX agent for transaction signing.
EOA_PRIVATE_KEY=

# Created from ARCOX AI Router. Leave empty until a key is created.
ARCOX_AI_ROUTER_API_KEY=

# Optional: separate key used only by the Hermes model provider. When empty,
# Hermes falls back to ARCOX_AI_ROUTER_API_KEY. It does not authorize MCP txs.
ARCOX_HERMES_API_KEY=

# Optional Solana signer for Solana Devnet actions.
SOLANA_PRIVATE_KEY=

# Public testnet configuration.
ARCOX_API_BASE_URL=https://arc-dex-bice.vercel.app
ARCOX_WEB_URL=https://arc-dex-bice.vercel.app
ARC_RPC_URL=https://rpc.testnet.arc.network/
ARC_CHAIN_ID=5042002
ARC_EXPLORER_URL=https://testnet.arcscan.app

# Local safety limits.
ARCOX_MAX_TX_USDC=10
ARCOX_DAILY_LIMIT_USDC=50
ARCOX_MAX_TX_NATIVE=0.1
